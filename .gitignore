# Python
__pycache__/
*.py[cod]

# Virtual envs
.venv/
.venv-ai-midi/

# macOS
.DS_Store

# Logs / temp
*.log
*.tmp

# --- Pipeline outputs: keep dirs, ignore contents ---
out_midis/*
!out_midis/.gitkeep

# If you want manifests NOT on GitHub, ignore JSONs but keep the folder:
manifests/*.json
!manifests/.gitkeep

# Keep these directories but ignore their contents by default
data/raw/*
data/stems/*
data/midi/*
!data/raw/.gitkeep
!data/stems/.gitkeep
!data/midi/.gitkeep

# Audio (don’t commit)
*.wav
*.aiff
*.aif
*.flac
*.mp3

# MIDI (don’t commit)
*.mid

# accidental backup files
.gitignore.save
